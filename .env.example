# ─── Mode IA ────────────────────────────────────────────────────────────────
# false = API Realtime OpenAI (cloud)
# true  = pipeline local (Whisper + Ollama + Piper)
USE_LOCAL_AI=false

# ─── Cloud : OpenAI ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Local : STT (faster-whisper) ────────────────────────────────────────────
WHISPER_URL=http://localhost:10300

# ─── Local : LLM (Ollama) ────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# ─── Local : TTS (piper-tts) ─────────────────────────────────────────────────
PIPER_URL=http://localhost:5000

# ─── Backend trottinette (WebSocket) ─────────────────────────────────────────
# L'ESP32 expose un serveur WS sur le port 8080
# Utiliser l'IP DHCP ou le nom mDNS enregistré par le firmware
SCOOTER_WS=ws://trottinette.local:8080

# ─── Authentification ────────────────────────────────────────────────────────
AUTH_USERNAME=admin
# Générer le hash : npm run hash-password -- VotreMotDePasse
AUTH_PASSWORD_HASH=$2b$12$...
# Clé secrète JWT (chaîne aléatoire longue)
JWT_SECRET=changez-moi-avec-une-longue-chaine-aleatoire

# ─── Serveur proxy ───────────────────────────────────────────────────────────
PROXY_PORT=3000

# ─── Cloudflare Tunnel ───────────────────────────────────────────────────────
# Token obtenu dans Cloudflare Zero Trust → Tunnels → créer un tunnel
# Route configurée dans le dashboard : trottinette.ve2fpd.com → http://proxy:3000
TUNNEL_TOKEN=eyJ...
